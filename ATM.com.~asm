ORG 100H
.DATA

USER1_PIN       DB '1','2','3','4'
USER1_SALDO     DW 10000
USER1_NAMA      DB 'ANANDA NURFADILAH$', 0


USER2_PIN       DB '4','3','2','1'
USER2_SALDO     DW 50000
USER2_NAMA      DB 'SITI AISYAH$', 0


CURRENT_USER    DB 0
PIN_INPUT       DB 4 DUP(?)
TEMP_INPUT      DW 0
TEMP_DIGIT      DB 0
TRANSFER_DEST   DB 0


LINE_DECOR      DB 0DH,0AH,'==================================================',0DH,0AH,'$'
MINI_LINE       DB 0DH,0AH,'--------------------------------------------------',0DH,0AH,'$'

MSG_WELCOME     DB 0DH,0AH,'         SELAMAT DATANG DI ATM PREMIUM 8086       ',0DH,0AH,'$'
MSG_CHOOSE_ACC  DB 0DH,0AH,'Silahkan Masukkan Kartu (Pilih Akun):',0DH,0AH
DB '1. Akun 1 (Ananda Nurfadilah)',0DH,0AH
DB '2. Akun 2 (Siti Aisyah)',0DH,0AH
DB 'Pilihan Anda (1-2): $'

MSG_ENTER_PIN   DB 0DH,0AH,'Masukkan 4 Digit PIN Anda: $'
MSG_PIN_WRONG   DB 0DH,0AH,'[ERR] PIN yang Anda masukkan salah!',0DH,0AH,'$'
MSG_AUTH_OK     DB 0DH,0AH,'[OK] Verifikasi Berhasil! Halo, $'


MSG_MENU_HDR    DB 0DH,0AH,'------------------ MENU UTAMA ------------------',0DH,0AH,'$'
MSG_MENU_1      DB '1. Cek Saldo Informasi',0DH,0AH,'$'
MSG_MENU_2      DB '2. Penarikan Tunai Fleksibel',0DH,0AH,'$'
MSG_MENU_3      DB '3. Setor Tunai Fleksibel',0DH,0AH,'$'
MSG_MENU_4      DB '4. Transfer Dana Uang',0DH,0AH,'$'
MSG_MENU_5      DB '5. Ubah PIN ATM Anda',0DH,0AH,'$'
MSG_MENU_6      DB '6. Keluar / Eject Kartu',0DH,0AH,'$'
MSG_MENU_CHOOSE DB 'Pilih Menu (1-6): $'


MSG_VAL_SALDO   DB 0DH,0AH,'Jumlah Saldo Anda saat ini adalah: $',0DH,0AH,'$'


MSG_TARIK_AMT   DB 0DH,0AH,'Masukkan jumlah penarikan (Kelipatan 100): $',0DH,0AH,'$'
MSG_TARIK_ERR1  DB 0DH,0AH,'[ERR] Saldo Anda tidak mencukupi!',0DH,0AH,'$'
MSG_TARIK_ERR2  DB 0DH,0AH,'[ERR] Batas penarikan minimum adalah $100!',0DH,0AH,'$'
MSG_TARIK_SUCCESS DB 0DH,0AH,'[SUCCESS] Penarikan berhasil dilakukan!',0DH,0AH,'$'


MSG_SETOR_AMT   DB 0DH,0AH,'Masukkan jumlah uang yang disetor: $',0DH,0AH,'$'
MSG_SETOR_ERR   DB 0DH,0AH,'[ERR] Batas maksimum setor tunai adalah $9000!',0DH,0AH,'$'
MSG_SETOR_SUCCESS DB 0DH,0AH,'[SUCCESS] Uang berhasil disetor ke rekening!',0DH,0AH,'$'


MSG_TX_DEST     DB 0DH,0AH,'Masukkan nomor rekening tujuan (1 atau 2): $',0DH,0AH,'$'
MSG_TX_AMT      DB 0DH,0AH,'Masukkan jumlah nominal transfer: $',0DH,0AH,'$'
MSG_TX_ERR_SELF DB 0DH,0AH,'[ERR] Tidak dapat mentransfer ke diri sendiri!',0DH,0AH,'$'
MSG_TX_ERR_BAL  DB 0DH,0AH,'[ERR] Dana Anda tidak cukup untuk transfer!',0DH,0AH,'$'
MSG_TX_SUCCESS  DB 0DH,0AH,'[SUCCESS] Transfer dana berhasil terkirim!',0DH,0AH,'$'


MSG_NEW_PIN     DB 0DH,0AH,'Masukkan 4 Digit PIN Baru Anda: $',0DH,0AH,'$'
MSG_PIN_CHANGED DB 0DH,0AH,'[SUCCESS] PIN Anda berhasil diperbarui!',0DH,0AH,'$'


MSG_INVALID     DB 0DH,0AH,'[ERR] Pilihan input salah atau tidak valid!',0DH,0AH,'$'
MSG_EXIT        DB 0DH,0AH,'Terima kasih telah bertransaksi di ATM kami.',0DH,0AH
DB 'Silahkan ambil kembali kartu Anda.',0DH,0AH,'$'
MSG_PRESS_KEY   DB 0DH,0AH,'Tekan tombol apa saja untuk kembali...',0DH,0AH,'$'


.CODE
MAIN PROC

MOV AX, @DATA
MOV DS, AX

START_SISTEM:

LEA DX, LINE_DECOR
CALL CETAK_STRING
LEA DX, MSG_WELCOME
CALL CETAK_STRING
LEA DX, LINE_DECOR
CALL CETAK_STRING


LEA DX, MSG_CHOOSE_ACC
CALL CETAK_STRING

MOV AH, 01H
INT 21H

CMP AL, '1'
JE SET_USER1
CMP AL, '2'
JE SET_USER2


LEA DX, MSG_INVALID
CALL CETAK_STRING
JMP START_SISTEM

SET_USER1:
MOV CURRENT_USER, 1
JMP PROSES_PIN

SET_USER2:
MOV CURRENT_USER, 2
JMP PROSES_PIN


PROSES_PIN:
LEA DX, MSG_ENTER_PIN
CALL CETAK_STRING

MOV CX, 4
MOV SI, 0

INPUT_PIN_LOOP:
MOV AH, 07H
INT 21H

MOV PIN_INPUT[SI], AL
MOV DL, '*'
MOV AH, 02H
INT 21H

INC SI
LOOP INPUT_PIN_LOOP
MOV CX, 4
MOV SI, 0

VALIDASI_PIN_LOOP:
MOV AL, PIN_INPUT[SI]
CMP CURRENT_USER, 1
JE CEK_PIN_USER1


CMP AL, USER2_PIN[SI]
JNE PIN_SALAH_PROSES
JMP NEXT_DIGIT

CEK_PIN_USER1:
CMP AL, USER1_PIN[SI]
JNE PIN_SALAH_PROSES

NEXT_DIGIT:
INC SI
LOOP VALIDASI_PIN_LOOP
JMP PIN_BENAR_PROSES

PIN_SALAH_PROSES:
LEA DX, MSG_PIN_WRONG
CALL CETAK_STRING
JMP START_SISTEM

PIN_BENAR_PROSES:
LEA DX, MSG_AUTH_OK
CALL CETAK_STRING


CMP CURRENT_USER, 1
JE TAMPIL_NAMA1
LEA DX, USER2_NAMA
CALL CETAK_STRING
JMP MENU_UTAMA_LOBBY

TAMPIL_NAMA1:
LEA DX, USER1_NAMA
CALL CETAK_STRING


MENU_UTAMA_LOBBY:
LEA DX, LINE_DECOR
CALL CETAK_STRING
LEA DX, MSG_MENU_HDR
CALL CETAK_STRING
LEA DX, MINI_LINE
CALL CETAK_STRING


LEA DX, MSG_MENU_1
CALL CETAK_STRING
LEA DX, MSG_MENU_2
CALL CETAK_STRING
LEA DX, MSG_MENU_3
CALL CETAK_STRING
LEA DX, MSG_MENU_4
CALL CETAK_STRING
LEA DX, MSG_MENU_5
CALL CETAK_STRING
LEA DX, MSG_MENU_6
CALL CETAK_STRING

LEA DX, MINI_LINE
CALL CETAK_STRING
LEA DX, MSG_MENU_CHOOSE
CALL CETAK_STRING


MOV AH, 01H
INT 21H


CMP AL, '1'
JE ROUTER_CEK_SALDO
CMP AL, '2'
JE ROUTER_TARIK
CMP AL, '3'
JE ROUTER_SETOR
CMP AL, '4'
JE ROUTER_TRANSFER
CMP AL, '5'
JE ROUTER_UBAH_PIN
CMP AL, '6'
JE ROUTER_KELUAR


LEA DX, MSG_INVALID
CALL CETAK_STRING
JMP MENU_UTAMA_LOBBY


ROUTER_CEK_SALDO:   JMP MENU_CEK_SALDO
ROUTER_TARIK:       JMP MENU_TARIK_TUNAI
ROUTER_SETOR:       JMP MENU_SETOR_TUNAI
ROUTER_TRANSFER:    JMP MENU_TRANSFER
ROUTER_UBAH_PIN:    JMP MENU_UBAH_PIN
ROUTER_KELUAR:      JMP MENU_PROSES_KELUAR


MENU_CEK_SALDO:
LEA DX, MINI_LINE
CALL CETAK_STRING
LEA DX, MSG_VAL_SALDO
CALL CETAK_STRING

CMP CURRENT_USER, 1
JE SALDO_U1

MOV AX, USER2_SALDO
CALL PROSEDUR_CETAK_ANGKA
JMP SELESAI_FITUR_1

SALDO_U1:
MOV AX, USER1_SALDO
CALL PROSEDUR_CETAK_ANGKA

SELESAI_FITUR_1:
CALL PROSEDUR_TUNGGU_KEY
JMP MENU_UTAMA_LOBBY


MENU_TARIK_TUNAI:
LEA DX, MSG_TARIK_AMT
CALL CETAK_STRING

CALL PROSEDUR_INPUT_ANGKA
MOV TEMP_INPUT, AX


CMP AX, 100
JB ERR_TARIK_MIN


CMP CURRENT_USER, 1
JE TARIK_VAL_U1


MOV BX, USER2_SALDO
CMP TEMP_INPUT, BX
JA ERR_TARIK_SALDO


MOV AX, TEMP_INPUT
SUB USER2_SALDO, AX
JMP TARIK_SUKSES_PROSES

TARIK_VAL_U1:
MOV BX, USER1_SALDO
CMP TEMP_INPUT, BX
JA ERR_TARIK_SALDO

; Eksekusi Pengurangan Saldo User 1
MOV AX, TEMP_INPUT
SUB USER1_SALDO, AX

TARIK_SUKSES_PROSES:
LEA DX, MSG_TARIK_SUCCESS
CALL CETAK_STRING
JMP SELESAI_FITUR_2

ERR_TARIK_MIN:
LEA DX, MSG_TARIK_ERR2
CALL CETAK_STRING
JMP SELESAI_FITUR_2

ERR_TARIK_SALDO:
LEA DX, MSG_TARIK_ERR1
CALL CETAK_STRING

SELESAI_FITUR_2:
CALL PROSEDUR_TUNGGU_KEY
JMP MENU_UTAMA_LOBBY


MENU_SETOR_TUNAI:
LEA DX, MSG_SETOR_AMT
CALL CETAK_STRING

CALL PROSEDUR_INPUT_ANGKA
MOV TEMP_INPUT, AX


CMP AX, 9000
JA ERR_SETOR_MAX


CMP CURRENT_USER, 1
JE SETOR_U1

MOV AX, TEMP_INPUT
ADD USER2_SALDO, AX
JMP SETOR_SUKSES_PROSES

SETOR_U1:
MOV AX, TEMP_INPUT
ADD USER1_SALDO, AX

SETOR_SUKSES_PROSES:
LEA DX, MSG_SETOR_SUCCESS
CALL CETAK_STRING
JMP SELESAI_FITUR_3

ERR_SETOR_MAX:
LEA DX, MSG_SETOR_ERR
CALL CETAK_STRING

SELESAI_FITUR_3:
CALL PROSEDUR_TUNGGU_KEY
JMP MENU_UTAMA_LOBBY


MENU_TRANSFER:
LEA DX, MSG_TX_DEST
CALL CETAK_STRING

MOV AH, 01H
INT 21H
SUB AL, '0'
MOV TRANSFER_DEST, AL


MOV BL, CURRENT_USER
CMP TRANSFER_DEST, BL
JE ERR_TX_SELF


CMP TRANSFER_DEST, 1
JE AMBIL_NOMINAL_TX
CMP TRANSFER_DEST, 2
JE AMBIL_NOMINAL_TX

LEA DX, MSG_INVALID
CALL CETAK_STRING
JMP SELESAI_FITUR_4

AMBIL_NOMINAL_TX:
LEA DX, MSG_TX_AMT
CALL CETAK_STRING
CALL PROSEDUR_INPUT_ANGKA
MOV TEMP_INPUT, AX


CMP CURRENT_USER, 1
JE TX_VAL_U1


MOV BX, USER2_SALDO
CMP TEMP_INPUT, BX
JA ERR_TX_BAL


MOV AX, TEMP_INPUT
SUB USER2_SALDO, AX
ADD USER1_SALDO, AX
JMP TX_SUKSES_PROSES

TX_VAL_U1:
MOV BX, USER1_SALDO
CMP TEMP_INPUT, BX
JA ERR_TX_BAL


MOV AX, TEMP_INPUT
SUB USER1_SALDO, AX
ADD USER2_SALDO, AX

TX_SUKSES_PROSES:
LEA DX, MSG_TX_SUCCESS
CALL CETAK_STRING
JMP SELESAI_FITUR_4

ERR_TX_SELF:
LEA DX, MSG_TX_ERR_SELF
CALL CETAK_STRING
JMP SELESAI_FITUR_4

ERR_TX_BAL:
LEA DX, MSG_TX_ERR_BAL
CALL CETAK_STRING

SELESAI_FITUR_4:
CALL PROSEDUR_TUNGGU_KEY
JMP MENU_UTAMA_LOBBY


MENU_UBAH_PIN:
LEA DX, MSG_NEW_PIN
CALL CETAK_STRING

MOV CX, 4
MOV SI, 0

INPUT_PIN_BARU:
MOV AH, 07H
INT 21H
MOV PIN_INPUT[SI], AL

MOV DL, '*'
MOV AH, 02H
INT 21H

INC SI
LOOP INPUT_PIN_BARU


MOV CX, 4
MOV SI, 0

UPDATE_PIN_LOOP:
MOV AL, PIN_INPUT[SI]
CMP CURRENT_USER, 1
JE UPDATE_U1

MOV USER2_PIN[SI], AL
JMP NEXT_UPDATE_DIGIT

UPDATE_U1:
MOV USER1_PIN[SI], AL

NEXT_UPDATE_DIGIT:
INC SI
LOOP UPDATE_PIN_LOOP

LEA DX, MSG_PIN_CHANGED
CALL CETAK_STRING
CALL PROSEDUR_TUNGGU_KEY
JMP MENU_UTAMA_LOBBY


MENU_PROSES_KELUAR:
LEA DX, LINE_DECOR
CALL CETAK_STRING
LEA DX, MSG_EXIT
CALL CETAK_STRING
LEA DX, LINE_DECOR
CALL CETAK_STRING


MOV AH, 4CH
INT 21H
MAIN ENDP


CETAK_STRING PROC NEAR
MOV AH, 09H
INT 21H
RET
CETAK_STRING ENDP


PROSEDUR_TUNGGU_KEY PROC NEAR
LEA DX, MSG_PRESS_KEY
MOV AH, 09H
INT 21H
MOV AH, 07H
INT 21H
RET
PROSEDUR_TUNGGU_KEY ENDP


PROSEDUR_CETAK_ANGKA PROC NEAR
MOV CX, 0
MOV BX, 10

PROSES_DIV_LOOP:
MOV DX, 0
DIV BX
PUSH DX
INC CX
CMP AX, 0
JNE PROSES_DIV_LOOP

PROSES_PRINT_LOOP:
POP DX
ADD DL, '0'
MOV AH, 02H
INT 21H
LOOP PROSES_PRINT_LOOP

RET
PROSEDUR_CETAK_ANGKA ENDP


PROSEDUR_INPUT_ANGKA PROC NEAR
MOV BX, 0
MOV TEMP_DIGIT, 0

LOOP_BACA_DIGIT:
MOV AH, 01H
INT 21H

CMP AL, 13
JE INPUT_ANGKA_SELESAI

CMP AL, '0'
JB LOOP_BACA_DIGIT
CMP AL, '9'
JA LOOP_BACA_DIGIT

SUB AL, '0'
MOV CL, AL
MOV CH, 0


MOV AX, BX
MOV DX, 10
MUL DX
MOV BX, AX
ADD BX, CX

INC TEMP_DIGIT
CMP TEMP_DIGIT, 5
JE INPUT_ANGKA_SELESAI
JMP LOOP_BACA_DIGIT

INPUT_ANGKA_SELESAI:
MOV AX, BX
RET
PROSEDUR_INPUT_ANGKA ENDP

END MAIN



